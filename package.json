{
  "name": "meta-scheduler",
  "version": "0.1.0",
  "description": "CLI tool for managing multiple Claude Code instances across remote workers",
  "type": "module",
  "bin": {
    "ms": "./dist/cli.js",
    "ms-agent": "./dist/agent-cli.js"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js && node dist/cli.js",
    "link": "npm run build && npm link",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
